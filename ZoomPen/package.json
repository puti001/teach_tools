{
  "name": "puti-ai-zpen",
  "version": "1.0.0",
  "description": "Puti-AI Z-Pen - 螢幕放大與畫筆工具",
  "main": "main.js",
  "author": "Puti-AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/puti001/teach_tools.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.puti-ai.zpen",
    "productName": "Puti-AI Z-Pen",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "portable": {
      "artifactName": "Puti-AI-Z-Pen.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
